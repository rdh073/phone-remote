# Precedence: .env is the committed baseline, .env.local (gitignored) wins for
# every key it defines. The hub loads both at boot in that order, and the
# Settings modal writes operator-edited values to .env.local so .env stays
# pristine. PATCH /api/settings hot-applies changes — most keys take effect
# immediately, restart-required keys are flagged in the UI.
HOST=127.0.0.1
PORT=4000

# Auth — ALL THREE are required at install time. The hub refuses to boot
# without them; there is no default `admin` user baked in. Generate with:
#   openssl rand -hex 32                                                    → SESSION_SECRET
#   pnpm -F @phone-remote/hub run hash-password "your-password"             → AUTH_PASSWORD_HASH
# AUTH_USER is the operator-chosen admin login name. Pick something that
# isn't `admin`/`root`/`administrator` to blunt credential-stuffing.
SESSION_SECRET=
AUTH_USER=
AUTH_PASSWORD_HASH=
# Set COOKIE_SECURE=true once a TLS terminator (Caddy/Tailscale Serve) is in front.
COOKIE_SECURE=false

# Headscale — fill in before provisioning works
# HEADSCALE_URL=https://headscale.example.com:8080
# HEADSCALE_API_KEY=hsa_replace_me
# HEADSCALE_USER_ID=1
PROVISION_TAG=tag:phone
PROVISION_EXPIRY_SEC=3600

# Path to the adb binary. Leave blank to fall back to `adb` on PATH.
# Inside the Docker image this is overridden to /usr/local/bin/adb.
ADB_PATH=adb
# Set ADB_AUTO_START=1 to start the local adb-server at hub boot. Without this
# the operator has to run `adb start-server` once after each reboot or /devices
# returns ECONNREFUSED 127.0.0.1:5037. The assistant also exposes
# adb_start_server / adb_kill_server / adb_restart_server tools.
ADB_AUTO_START=1
LOG_LEVEL=info

# scrcpy stream presets. Settable from the Settings → Video panel. Read at
# session-launch (next-stream takes new values; live sessions keep theirs).
# Defaults reproduce the original hardcoded values (1280 / 6 Mbps / 30 fps).
# main = focused tile, thumb = grid thumbnail. Bitrate in bits/sec.
SCRCPY_MAIN_MAX_SIZE=1280
SCRCPY_MAIN_VIDEO_BITRATE=6000000
SCRCPY_MAIN_MAX_FPS=30
SCRCPY_THUMB_MAX_SIZE=1280
SCRCPY_THUMB_VIDEO_BITRATE=6000000
SCRCPY_THUMB_MAX_FPS=30

# Operator assistant — POST /api/assistant/chat. The web panel switches between
# providers it sees as available in GET /api/assistant/catalog. Enable at least one:
#
#   Claude OAuth (no API key)
#     CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...                    # wins over credentials.json
#                                                            # treated as long-lived, no refresh
#     PHONE_REMOTE_CLAUDE_CREDS=/path/to/.credentials.json   # optional override of ~/.claude/.credentials.json
#                                                            # (ignored when CLAUDE_OAUTH_TOKEN is set)
#
#   Anthropic API
#     ANTHROPIC_API_KEY=sk-ant-…
#
#   OpenAI (or OpenAI-shaped endpoint)
#     OPENAI_API_KEY=sk-…
#     OPENAI_BASE_URL=https://api.openai.com/v1              # optional
#
#   Google Gemini
#     GOOGLE_GENERATIVE_AI_API_KEY=…
#
#   DeepSeek
#     DEEPSEEK_API_KEY=sk-…
#
#   Ollama (remote — TLS verification is disabled for this provider so IP-based
#     HTTPS endpoints with hostname-mismatched certs work)
#     OLLAMA_BASE_URL=https://136.24.37.174:8443/v1          # OpenAI-compat path, /v1
#
#   Generic OpenAI-compatible (OpenRouter, Together, Groq, vLLM, etc.)
#     OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
#     OPENAI_COMPATIBLE_API_KEY=…                            # optional
#     OPENAI_COMPATIBLE_LABEL=OpenRouter                      # optional UI label
ASSISTANT_MAX_STEPS=20
